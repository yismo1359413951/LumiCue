        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tự động ẩn thẻ nổi khi cửa sổ Annotate, Video Editor hoặc Cloud Uploads được mở để giữ không gian làm việc gọn gàng"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开批注、视频编辑器或云端上传窗口时自动隐藏浮动卡片，以保持工作区整洁"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "打開標註、影片編輯器或雲端上傳視窗時自動隱藏浮動卡片，以保持工作區整潔"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar automáticamente la tarjeta flotante cuando se abre la ventana Anotar, Editor de Video o Subidas a la Nube"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "注釈、動画エディタ、またはクラウドアップロードウィンドウを開いたときにフローティングカードを自動的に非表示にする"
          }
