    "preferences-quick-access.swipe-actions-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehen Sie Aktionen auf die kreisförmigen Wischziele, um auszuwählen, was nach einem Wischen mit zwei Fingern ausgeführt wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag actions onto the circular swipe targets to choose what runs after a two-finger swipe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra acciones a los objetivos de deslizamiento circulares para elegir qué se ejecuta después de un deslizamiento con dos dedos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glissez des actions sur les cibles de balayage circulaires pour choisir ce qui s'exécute après un balayage à deux doigts."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "円形の swipe ターゲットにアクションをドラッグして、2本指でスワイプした後に実行する操作を選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "두 손가락 스와이프 후 실행할 작업을 선택하려면 원형 스와이프 대상으로 작업을 드래그하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите действия на круглые цели для смахивания, чтобы выбрать, что будет запускаться после смахивания двумя пальцами."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kéo các hành động vào mục tiêu vuốt hình tròn để chọn hành động sẽ chạy sau khi vuốt bằng hai ngón tay."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将操作拖动到圆形滑动目标上，以选择在双指轻扫后运行什么操作。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將操作拖移到圓形滑動目標上，以選擇在雙指輕掃後執行什麼操作。"
