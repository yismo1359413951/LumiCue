    "preferences-quick-access.quick-actions-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehe Listenzeilen, um das Kontextmenü neu anzuordnen. Ziehe Aktionen auf die Vorschau, um Kartenpositionen festzulegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag list rows to reorder the context menu. Drag actions onto the preview to set card positions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra las filas de la lista para reordenar el menú contextual. Arrastra acciones a la vista previa para definir posiciones en la tarjeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser les lignes de la liste pour réorganiser le menu contextuel. Faites glisser des actions sur l’aperçu pour définir les positions de la carte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リストの行をドラッグしてコンテキストメニューを並べ替えます。アクションをプレビューへドラッグしてカード上の位置を設定します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "목록 행을 드래그해 컨텍스트 메뉴 순서를 바꾸세요. 액션을 미리보기로 드래그해 카드 위치를 설정하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетаскивайте строки списка, чтобы изменить порядок контекстного меню. Перетаскивайте действия на предпросмотр, чтобы задать позиции на карточке."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kéo các dòng trong danh sách để sắp xếp lại menu ngữ cảnh. Kéo thao tác vào bản xem trước để đặt vị trí trên thẻ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动列表行以重新排列上下文菜单。将操作拖到预览上以设置卡片位置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "拖曳列表列以重新排列內容選單。將動作拖到預覽上以設定卡片位置。"
          }
        }
      }
    },
