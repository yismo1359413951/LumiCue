    "annotate.jpeg-removes-transparency-message": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Bild verwendet einen transparenten Hintergrundausschnitt. Beim Speichern als JPEG wird die Transparenz auf einen undurchsichtigen Hintergrund reduziert. Verwenden Sie PNG oder WebP, um die Transparenz aufrechtzuerhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This image uses a transparent background cutout. Saving as JPEG will flatten transparency to an opaque background. Use PNG or WebP to keep transparency."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta imagen utiliza un recorte de fondo transparente. Guardar como JPEG aplanará la transparencia a un fondo opaco. Utilice PNG o WebP para mantener la transparencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette image utilise une découpe d'arrière-plan transparente. L'enregistrement au format JPEG aplatira la transparence sur un arrière-plan opaque. Utilisez PNG ou WebP pour conserver la transparence."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この画像は透明な背景の切り抜きを使用しています。 JPEG として保存すると、透明度が不透明な背景に平坦化されます。透明性を維持するには、PNG または WebP を使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 이미지는 투명한 배경 컷아웃을 사용합니다. JPEG로 저장하면 투명도가 불투명한 배경으로 병합됩니다. 투명성을 유지하려면 PNG 또는 WebP를 사용하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В этом изображении используется вырез на прозрачном фоне. Сохранение в формате JPEG приведет к выравниванию прозрачности до непрозрачного фона. Используйте PNG или WebP, чтобы сохранить прозрачность."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hình ảnh này đang dùng nền trong suốt sau khi tách nền. Lưu dưới dạng JPEG sẽ làm phẳng nền trong suốt thành nền đục. Hãy dùng PNG hoặc WebP để giữ nền trong suốt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该图像使用透明背景剪切。保存为 JPEG 会将透明度拼合为不透明背景。使用 PNG 或 WebP 来保持透明度。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該圖像使用透明背景剪切。保存為 JPEG 會將透明度拼合為不透明背景。使用 PNG 或 WebP 來保持透明度。"
          }
        }
      }
    },
