    "annotate.overwrite-cloud-file-message": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Bild wurde zuvor in die Cloud hochgeladen. Durch ein erneutes Hochladen wird die vorhandene Datei durch Ihre Änderungen ersetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This image was previously uploaded to cloud. Re-uploading will replace the existing file with your changes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta imagen se subió previamente a la nube. Volver a cargar reemplazará el archivo existente con sus cambios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette image a déjà été téléchargée sur le cloud. Le nouveau téléchargement remplacera le fichier existant par vos modifications."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この画像は以前にクラウドにアップロードされました。再アップロードすると、既存のファイルが変更内容で置き換えられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 이미지는 이전에 클라우드에 업로드되었습니다. 다시 업로드하면 기존 파일이 변경사항으로 대체됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это изображение ранее было загружено в облако. При повторной загрузке существующий файл будет заменен вашими изменениями."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hình ảnh này đã từng được tải lên Cloud. Tải lên lại sẽ thay thế tệp hiện có bằng phiên bản đã chỉnh sửa của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这张图片之前已经上传到云端。重新上传将用您的更改替换现有文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這張圖片之前已經上傳到雲端。重新上傳將用您的更改替換現有檔案。"
          }
        }
      }
    },
