          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không thể căn chỉnh khung hình đó. Hãy giữ cùng một hướng và nhịp cuộn ổn định hơn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法对齐该框架。保持相同的方向和更稳定的步伐。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法對齊該框架。保持相同的方向和更穩定的步伐。"
          }
        }
      }
    },
