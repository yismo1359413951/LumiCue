    "cloud-settings.password-tooltip": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optionales Passwort zum Schutz der Anmeldeinformationen vor unbefugtem Zugriff"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional password to protect credentials from unauthorized access"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Contraseña opcional para proteger las credenciales del acceso no autorizado"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mot de passe facultatif pour protéger les informations d'identification contre tout accès non autorisé"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "資格情報を不正アクセスから保護するためのオプションのパスワード"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무단 액세스로부터 자격 증명을 보호하기 위한 선택적 비밀번호"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дополнительный пароль для защиты учетных данных от несанкционированного доступа"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mật khẩu tùy chọn để bảo vệ thông tin đăng nhập khỏi truy cập trái phép"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选密码可保护凭证免遭未经授权的访问"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選密碼可保護憑證免遭未經授權的訪問"
          }
        }
      }
    },
