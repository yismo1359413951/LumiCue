          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "钥匙串交互目前不可用。解锁您的 Mac，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
