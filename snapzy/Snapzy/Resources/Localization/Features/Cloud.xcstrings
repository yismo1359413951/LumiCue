        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keychain access was not granted. Allow access and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se concedió el acceso al llavero. Permita el acceso y vuelva a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès au trousseau n'a pas été accordé. Autorisez l'accès et réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーチェーンへのアクセスが許可されませんでした。アクセスを許可して、再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키체인 접근 권한이 부여되지 않았습니다. 액세스를 허용하고 다시 시도하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к связке ключей не предоставлен. Разрешите доступ и повторите попытку."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quyền truy cập Keychain bị từ chối. Hãy cho phép truy cập và thử lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未授予钥匙串访问权限。允许访问并重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未授予鑰匙串訪問權限。允許訪問並重試。"
          }
        }
      }
    },
    "cloud-password.keychain-interaction-unavailable": {
