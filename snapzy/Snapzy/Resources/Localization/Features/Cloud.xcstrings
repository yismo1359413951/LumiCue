    "cloud-settings.reset-configuration-message": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle Cloud-Anmeldeinformationen, das Schutzkennwort und alle Einstellungen entfernt. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will remove all cloud credentials, protection password, and settings. This action cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará todas las credenciales de la nube, la contraseña de protección y la configuración. Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera toutes les informations d'identification cloud, le mot de passe de protection et les paramètres. Cette action ne peut pas être annulée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これにより、すべてのクラウド認証情報、保護パスワード、設定が削除されます。この操作は元に戻すことができません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "그러면 모든 클라우드 자격 증명, 보호 비밀번호 및 설정이 제거됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При этом будут удалены все облачные учетные данные, пароль защиты и настройки. Это действие невозможно отменить."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa toàn bộ thông tin đăng nhập Cloud, mật khẩu bảo vệ và cài đặt. Hành động này không thể hoàn tác."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将删除所有云凭据、保护密码和设置。此操作无法撤消。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將刪除所有雲憑據、保護密碼和設置。此操作無法撤消。"
          }
        }
      }
    },
    "cloud-settings.reset-configuration-title": {
