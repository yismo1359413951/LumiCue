    "onboarding.diagnostics.privacy-note" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es werden keine personenbezogenen Daten erhoben. Ohne Ihr Zutun wird nichts gesendet."
