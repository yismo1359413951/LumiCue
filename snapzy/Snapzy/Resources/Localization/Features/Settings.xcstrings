    "preferences-advanced.restore-defaults-confirmation-message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du bestätigst, ersetzt Snapzy config.toml durch Standardwerte, setzt App-Einstellungen zurück und löscht Cloud-Zugangsdaten. Gespeicherte Aufnahmen werden nicht gelöscht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you confirm, Snapzy will replace config.toml with default values, reset app settings, and clear cloud credentials. Saved captures are not deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si confirmas, Snapzy reemplazará config.toml con valores predeterminados, restablecerá los ajustes de la app y borrará las credenciales de la nube. Las capturas guardadas no se eliminan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous confirmez, Snapzy remplacera config.toml par les valeurs par défaut, réinitialisera les réglages de l’app et effacera les identifiants cloud. Les captures enregistrées ne sont pas supprimées."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認すると、Snapzy は config.toml をデフォルト値で置き換え、アプリ設定をリセットし、クラウド認証情報を消去します。保存済みのキャプチャは削除されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인하면 Snapzy가 config.toml을 기본값으로 교체하고 앱 설정을 재설정하며 클라우드 자격 증명을 지웁니다. 저장된 캡처는 삭제되지 않습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если подтвердить действие, Snapzy заменит config.toml значениями по умолчанию, сбросит настройки приложения и удалит облачные учетные данные. Сохраненные снимки не удаляются."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nếu xác nhận, Snapzy sẽ thay config.toml bằng giá trị mặc định, đặt lại cài đặt ứng dụng và xóa thông tin đăng nhập cloud. Ảnh và bản ghi đã lưu sẽ không bị xóa."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确认后，Snapzy 会用默认值替换 config.toml，重置应用设置，并清除云端凭据。已保存的捕捉内容不会被删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確認後，Snapzy 會用預設值取代 config.toml，重置 App 設定，並清除雲端憑證。已儲存的擷取內容不會被刪除。"
          }
        }
      }
    },
