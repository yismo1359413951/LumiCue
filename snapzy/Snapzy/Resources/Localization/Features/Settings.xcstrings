            "state": "translated",
            "value": "Синхронизировать config.toml?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đồng bộ config.toml?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步 config.toml？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "同步 config.toml？"
          }
        }
      }
    },
