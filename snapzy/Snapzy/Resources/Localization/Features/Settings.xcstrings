    "preferences-advanced.config-sync-idle-description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktuelle Einstellungen werden automatisch mit config.toml synchronisiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Current settings will sync to config.toml automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los ajustes actuales se sincronizarán automáticamente con config.toml."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les réglages actuels seront synchronisés automatiquement avec config.toml."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の設定は自動的に config.toml と同期されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 설정이 config.toml과 자동으로 동기화됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Текущие настройки будут автоматически синхронизироваться с config.toml."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cài đặt hiện tại sẽ tự động đồng bộ vào config.toml."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前设置会自动同步到 config.toml。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前設定會自動同步到 config.toml。"
          }
        }
      }
    },
    "preferences-advanced.config-sync-queued-description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync vorgemerkt. Snapzy aktualisiert config.toml in Kürze."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync queued. Snapzy will update config.toml shortly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincronización en cola. Snapzy actualizará config.toml en breve."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronisation en attente. Snapzy mettra config.toml à jour bientôt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期を予約しました。Snapzy がまもなく config.toml を更新します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동기화가 대기 중입니다. Snapzy가 곧 config.toml을 업데이트합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Синхронизация поставлена в очередь. Snapzy скоро обновит config.toml."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã xếp hàng đồng bộ. Snapzy sẽ cập nhật config.toml sau ít giây."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步已排队。Snapzy 稍后会更新 config.toml。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "同步已排程。Snapzy 稍後會更新 config.toml。"
          }
        }
      }
    },
    "preferences-advanced.config-sync-synced-description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "config.toml wurde um %@ aus den aktuellen Einstellungen aktualisiert."
          }
        },
        "en": {
