            "state": "translated",
            "value": "需要採取行動"
          }
        }
      }
    },
    "preferences-shortcuts.annotate-actions-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verknüpfungen für allgemeine Aktionen im Anmerkungseditor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcuts for common actions inside the annotation editor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesos directos para acciones comunes dentro del editor de anotaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccourcis pour les actions courantes dans l'éditeur d'annotations."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "注釈エディタ内の一般的なアクションのショートカット。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주석 편집기 내의 일반적인 작업에 대한 단축키입니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ярлыки для общих действий в редакторе аннотаций."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phím tắt cho các thao tác phổ biến bên trong trình chỉnh sửa Annotate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标注编辑器内常用操作的快捷键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "標註編輯器中常用操作的快速鍵。"
          }
        }
      }
    },
    "preferences-shortcuts.annotation-tool-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tastenkombinationen zum Wechseln der Werkzeuge im Anmerkungseditor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single-key shortcuts for switching tools in the annotation editor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Atajos de una sola tecla para cambiar de herramienta en el editor de anotaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccourcis à une seule touche pour changer d'outil dans l'éditeur d'annotations."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "注釈エディターでツールを切り替えるための単一キーのショートカット。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주석 편집기에서 도구 전환을 위한 단일 키 단축키입니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Одноклавишные сочетания клавиш для переключения инструментов в редакторе аннотаций."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phím tắt một phím để chuyển công cụ trong trình chỉnh sửa Annotate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于在注释编辑器中切换工具的单键快捷键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用於在注釋編輯器中切換工具的單鍵快捷鍵。"
          }
        }
      }
    },
    "preferences-shortcuts.application-capture-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im Bereichsaufnahme-Overlay."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single key (A) pairs with Capture Area; modifier combo (⇧⌘A)\nworks independently."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dentro de la superposición de Captura de Área."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans la surcouche Capture de zone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "範囲キャプチャのオーバーレイ内"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "영역 캡처 오버레이 안에서"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Внутри оверлея захвата области."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phím đơn (A) đi cùng Chụp vùng; combo modifier (⇧⌘A)\nchạy độc lập."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在区域截屏叠加层中使用"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "於區域截圖疊加層中使用"
          }
        }
      }
    },
    "preferences-shortcuts.application-capture-title": {
      "extractionState": "stale",
      "localizations": {
