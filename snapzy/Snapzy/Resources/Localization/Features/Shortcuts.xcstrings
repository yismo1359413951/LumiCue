    "preferences-shortcuts.auto-redact-sensitive-data-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sensiblen Text lokal finden und bearbeitbare Weichzeichnungsanmerkungen hinzufügen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find sensitive text locally and add editable blur annotations"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscar texto confidencial localmente y agregar anotaciones de desenfoque editables"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechercher localement du texte sensible et ajouter des annotations de flou modifiables"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルで機密テキストを検索し、編集可能なぼかし注釈を追加します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬에서 민감한 텍스트를 찾아 편집 가능한 블러 주석을 추가합니다"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локальный поиск конфиденциального текста и добавление редактируемых размытий"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tìm văn bản nhạy cảm cục bộ và thêm các chú thích làm mờ có thể chỉnh sửa"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在本地查找敏感文本并添加可编辑的模糊标注"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在本地尋找敏感文字並新增可編輯的模糊標註"
          }
        }
      }
    },
    "preferences-shortcuts.capture-active-window-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfasst das fokussierte Fenster sofort, ohne Auswahlschritt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Instantly captures the focused window, no selection step"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Captura al instante la ventana activa, sin paso de selección"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture instantanément la fenêtre active, sans étape de sélection"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択操作なしでフォーカスされたウィンドウを即座にキャプチャします"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택 단계 없이 포커스된 창을 즉시 캡처합니다"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мгновенно захватывает активное окно без шага выбора"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chụp ngay cửa sổ đang được focus, không cần bước chọn"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "立即捕获当前聚焦的窗口，无需选择步骤"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "立即擷取目前聚焦的視窗，無需選取步驟"
          }
        }
      }
    },
    "preferences-shortcuts.capture-area-annotate-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Region auswählen, direkt markieren und mit ⌘S oder Eingabetaste abschließen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select a region, mark it up in place, then finish with ⌘S or Enter"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleccione una región, márquela en el lugar y termine con ⌘S o Intro"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez une zone, marquez-la sur place, puis terminez avec ⌘S ou Entrée"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "範囲を選択し、その場でマークアップして、⌘S または Enter で完了"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "영역을 선택하고 그 자리에서 마크업한 뒤 ⌘S 또는 Enter로 완료"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите область, разметьте ее на месте и завершите с помощью ⌘S или Enter"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn vùng, chú thích trực tiếp, rồi hoàn tất bằng ⌘S hoặc Enter"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择区域，直接标记，然后按 ⌘S 或 Enter 完成"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇區域，直接標記，然後按 ⌘S 或 Enter 完成"
          }
        }
      }
    },
