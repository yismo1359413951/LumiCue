    "preferences-shortcuts.system-conflict-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren Sie die überlappenden macOS-Verknüpfungen, um Konflikte mit den Snapzy-Verknüpfungen zu vermeiden, die Sie aktiviert lassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn off the overlapping macOS shortcuts to avoid conflicts with the Snapzy shortcuts you keep enabled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactive los atajos de macOS superpuestos para evitar conflictos con los atajos de Snapzy que mantiene habilitados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivez les raccourcis macOS qui se chevauchent pour éviter les conflits avec les raccourcis Snapzy que vous gardez activés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にした Snapzy ショートカットとの競合を避けるには、重複する macOS ショートカットをオフにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성화된 Snapzy 단축키와의 충돌을 방지하려면 겹치는 macOS 단축키를 끄세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключите перекрывающиеся ярлыки macOS, чтобы избежать конфликтов с ярлыками Snapzy, которые вы оставляете включенными."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tắt các phím tắt macOS bị trùng để tránh xung đột với các phím tắt Snapzy mà bạn muốn giữ bật."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭重叠的 macOS 快捷方式，以避免与您保持启用的 Snapzy 快捷方式发生冲突。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉重疊的 macOS 快捷方式，以避免與您保持啓用的 Snapzy 快捷方式發生衝突。"
          }
        }
      }
    },
