          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chụp ứng dụng"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用窗口截屏"
          }
