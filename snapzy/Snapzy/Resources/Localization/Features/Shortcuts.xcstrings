            "value": "Action requise"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクションが必要です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "필요한 조치"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Требуется действие"
          }
