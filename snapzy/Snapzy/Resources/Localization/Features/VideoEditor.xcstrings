          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅当此缩放项目处于活动状态时，摄像机位置才会遵循记录的鼠标路径。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
