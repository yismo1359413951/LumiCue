          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La posición de la cámara sigue la ruta grabada del mouse solo mientras este elemento de zoom está activo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
