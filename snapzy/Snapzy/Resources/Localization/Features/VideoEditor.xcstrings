          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Положение камеры следует записанному пути мыши только тогда, когда этот элемент масштабирования активен."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
