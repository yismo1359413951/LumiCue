    "whats-new.smart-element.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Smart Element Capture"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Intelligente Elementerfassung"
          }
        },
        "es": {
