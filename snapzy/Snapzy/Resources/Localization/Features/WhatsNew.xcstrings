    "whats-new.smart-element.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-detect and capture UI elements like windows and buttons."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erkennen und erfassen Sie UI-Elemente wie Fenster und Schaltflächen automatisch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detecta y captura automáticamente elementos de la interfaz de usuario, como ventanas y botones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Détectez et capturez automatiquement les éléments d'interface utilisateur tels que les fenêtres et les boutons."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ウィンドウやボタンなどのUI要素を自動検出してキャプチャします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "창 및 버튼과 같은 UI 요소를 자동 감지하고 캡처합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически обнаруживайте и захватывайте элементы интерфейса, такие как окна и кнопки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动检测并捕捉 UI 元素，如窗口和按钮。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動偵測並捕捉 UI 元素，如視窗和按鈕。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tự động phát hiện và chụp các thành phần giao diện như cửa sổ và nút bấm."
          }
        }
      }
    },
    "whats-new.shortcut.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Shortcut"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schnelltaste"
          }
        },
        "es": {
