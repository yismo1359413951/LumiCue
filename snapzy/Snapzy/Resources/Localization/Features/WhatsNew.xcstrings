            "value": "クイックショートカット"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빠른 단축키"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Быстрое сочетание клавиш"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速快捷键"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速快捷鍵"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phím tắt nhanh"
          }
        }
      }
    },
    "whats-new.shortcut.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press ⌥⇧4 anywhere to instantly activate this mode."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken Sie überall ⌥⇧4, um diesen Modus sofort zu aktivieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presiona ⌥⇧4 en cualquier lugar para activar instantáneamente este modo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur ⌥⇧4 n'importe où pour activer instantanément ce mode."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どこでも ⌥⇧4 を押すと、即座にこのモードがアクティブになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어디서나 ⌥⇧4를 눌러 이 모드를 즉시 활성화하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите ⌥⇧4 в любом месте, чтобы мгновенно активировать этот режим."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在任意位置按下 ⌥⇧4 即可立即激活此模式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在任意位置按下 ⌥⇧4 即可立即啟用此模式。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhấn ⌥⇧4 ở bất kỳ đâu để kích hoạt ngay chế độ này."
          }
        }
      }
    },
    "whats-new.ready.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ready to Capture"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bereit zur Erfassung"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Listo para capturar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prêt à capturer"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャプチャの準備完了"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캡처 준비 완료"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Готово к захвату"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "准备截图"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "準備截圖"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sẵn sàng chụp"
          }
        }
      }
    },
    "whats-new.ready.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hover over any element to highlight, then click to capture."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewegen Sie den Mauszeiger über ein Element, um es hervorzuheben, und klicken Sie dann zur Erfassung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pase el cursor sobre cualquier elemento para resaltarlo y luego haga clic para capturar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Survolez n'importe quel élément pour le mettre en surbrillance, puis cliquez pour capturer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "要素の上にカーソルを置くとハイライト表示され、クリックするとキャプチャされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "요소 위에 마우스를 올려 강조 표시한 다음 클릭하여 캡처합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Наведите курсор на любой элемент, чтобы выделить его, затем нажмите, чтобы захватить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将鼠标悬停在任意元素上以高亮显示，然后单击以截图。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將游標懸停在任意元素上以反白顯示，然後按一下以截圖。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Di chuột qua bất kỳ thành phần nào để làm nổi bật, sau đó nhấp để chụp."
          }
        }
      }
    },
