            "state": "translated",
            "value": "Entdecken Sie die neuesten Funktionen in Version %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descubre las últimas funciones de la versión %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Découvrez les dernières nouveautés de la version %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バージョン %@ の最新機能をご覧ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "버전 %@의 최신 기능을 확인해 보세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте для себя новые функции в версии %@."
          }
        },
        "zh-Hans": {
