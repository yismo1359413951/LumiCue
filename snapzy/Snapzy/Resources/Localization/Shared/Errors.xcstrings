    },
    "crash-report.alert-message" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy hat Ihre Diagnoseprotokolle in einer Datei gebündelt. Ziehen Sie die Datei unten auf die Berichtsseite."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy bundled your diagnostic logs into one file. Drag the file below to the report page."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy agrupó tus logs de diagnóstico en un archivo. Arrastra el archivo siguiente a la página de informe."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy a regroupé vos journaux de diagnostic dans un fichier. Faites glisser le fichier ci-dessous vers la page de rapport."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy は診断ログを1つのファイルにまとめました。下のファイルを報告ページへドラッグしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy가 진단 로그를 하나의 파일로 묶었습니다. 아래 파일을 신고 페이지로 드래그하세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy собрал журналы диагностики в один файл. Перетащите файл ниже на страницу отчета."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy đã gom log chẩn đoán thành một tệp. Hãy kéo tệp bên dưới vào trang báo lỗi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy 已将诊断日志打包为一个文件。将下面的文件拖到报告页面。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy 已將診斷日誌打包成一個檔案。將下面的檔案拖到回報頁面。"
          }
        }
      }
    },
    "crash-report.alert-message-no-log-bundle" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy konnte kein Diagnose-Log-Bundle vorbereiten. Sie können die Berichtsseite trotzdem öffnen und das Problem beschreiben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy could not prepare a diagnostic log bundle. You can still open the report page and describe the problem."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy no pudo preparar un paquete de logs de diagnóstico. Aun así puedes abrir la página de informe y describir el problema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy n’a pas pu préparer de lot de journaux de diagnostic. Vous pouvez quand même ouvrir la page de rapport et décrire le problème."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy は診断ログバンドルを準備できませんでした。報告ページを開いて問題を説明することはできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy가 진단 로그 묶음을 준비하지 못했습니다. 신고 페이지를 열어 문제를 설명할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy не удалось подготовить пакет журналов диагностики. Вы все равно можете открыть страницу отчета и описать проблему."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy không thể chuẩn bị gói log chẩn đoán. Bạn vẫn có thể mở trang báo lỗi và mô tả vấn đề."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy 无法准备诊断日志包。你仍然可以打开报告页面并描述问题。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy 無法準備診斷日誌包。你仍然可以開啟回報頁面並描述問題。"
          }
        }
      }
