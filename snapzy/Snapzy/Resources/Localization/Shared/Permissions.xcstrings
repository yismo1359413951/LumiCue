{
  "sourceLanguage" : "en",
  "strings" : {
    "file-access.bookmark-save-failed-message" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy konnte den Zugriff auf diesen Ordner nicht aufrechterhalten. Bitte wählen Sie den Ordner erneut aus und bestätigen Sie die Berechtigung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy could not persist access to this folder. Please choose the folder again and confirm permission."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy no pudo mantener el acceso a esta carpeta. Elija la carpeta nuevamente y confirme el permiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy n'a pas pu conserver l'accès à ce dossier. Veuillez choisir à nouveau le dossier et confirmer l'autorisation."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy はこのフォルダーへのアクセスを維持できませんでした。もう一度フォルダーを選択し、許可を確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy는 이 폴더에 대한 액세스를 유지할 수 없습니다. 폴더를 다시 선택하고 권한을 확인해 주세요."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy не удалось сохранить доступ к этой папке. Пожалуйста, выберите папку еще раз и подтвердите разрешение."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy không thể lưu quyền truy cập thư mục này. Vui lòng chọn lại thư mục và xác nhận quyền."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy 无法持久访问此文件夹。请再次选择该文件夹并确认权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snapzy 無法持久訪問此檔案夾。請再次選擇該檔案夾並確認權限。"
          }
        }
      }
    },
